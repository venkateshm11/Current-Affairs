rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only access their own document and subcollections
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;

        match /{subSubCollection}/{subDocId} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
        }
      }
    }

    // Shared daily content pool (Phase 7). Non-user-identifying content only —
    // no uid/email/displayName is ever written here. Any authenticated user may read
    // the pool and create a day's doc, but docs are immutable once written.
    match /sharedDaily/{docId} {
      allow read:   if request.auth != null;   // authenticated reads only — no public access
      allow create: if request.auth != null;   // create fires only when the doc does not yet exist
      allow update, delete: if false;           // immutable — no overwrites, no deletes
    }

    // Deny all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
